{
  "name": "backend",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main.js",
    "start:dev": "node --import @swc-node/register/esm-register src/main.ts",
    "start:debug": "tsx --inspect-brk watch src/main.ts",
    "start:prod": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma && prisma generate --schema=prisma/schema.postgresql.prisma",
    "prisma:push:mongodb": "prisma db push --schema=prisma/schema.prisma",
    "prisma:push:postgresql": "prisma db push --schema=prisma/schema.postgresql.prisma",
    "prisma:migrate:postgresql": "prisma migrate dev --schema=prisma/schema.postgresql.prisma"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "5.1.6",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/multipart": "10.0.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/static": "9.1.3",
    "@mastra/core": "1.41.0",
    "@nestjs/cache-manager": "3.1.2",
    "@nestjs/common": "11.1.26",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.26",
    "@nestjs/event-emitter": "3.1.0",
    "@nestjs/platform-fastify": "11.1.26",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.4",
    "@prisma/client": "6.19.0",
    "axios": "^1.17.0",
    "cache-manager": "7.2.8",
    "cache-manager-ioredis-yet": "2.1.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cloudinary": "2.10.0",
    "fastify": "5.8.5",
    "ioredis": "5.11.1",
    "nestjs-pino": "4.6.1",
    "pino": "10.3.1",
    "prisma": "6.19.0",
    "razorpay": "2.9.6",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.26",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.40",
    "@types/node": "25.9.2",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.8",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "supertest": "7.2.2",
    "tsc-alias": "1.8.17",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "4.1.8"
  }
}
