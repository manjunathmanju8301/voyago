{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "src",
    "declaration": true,
    "removeComments": true,
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
    "incremental": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}
